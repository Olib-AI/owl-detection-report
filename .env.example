OWL_BROWSER_URL=http://localhost:8081
OWL_BROWSER_TOKEN=your-owl-browser-token
# OWL_API_PREFIX=/api        # default: /api (via nginx). Set to empty string for direct port 8080

AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET=your-s3-bucket
S3_PREFIX=detection-reports
AWS_REGION=us-east-1
CLOUDFRONT_DISTRIBUTION_ID=optional-distribution-id
